{
  "name": "outboundautonomy",
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "^/demo/?$",
      "dest": "/sample-report",
      "status": 307
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}

      "id": "2169361a-1950-4bec-be76-dc59dd640c06"
    },
    {
      "name": "Beat Info",
      "type": "n8n-nodes-base.set",
      "parameters": {
        "values": {
          "string": [
            {
              "name": "beat_name",
              "value": "Untitled Beat"
            },
            {
              "name": "bpm",
              "value": "140"
            },
            {
              "name": "genre",
              "value": "Trap/Hip-Hop"
            },
            {

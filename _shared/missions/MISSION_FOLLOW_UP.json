  "skills_used":["business-writing","sales-mastery","Sales Pipeline Tracker"],
  "completion":{"all_artifacts_present":true,"audit_pass":true,"approval_granted":true},
  "notes":"Append to _shared/revenue/attempts.jsonl with state='approved' on grant; only flip to 'sent' after delivery evidence is captured."

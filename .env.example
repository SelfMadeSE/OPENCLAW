# ============================================================
# OPENCLAW — Environment Config
# !! NEVER COMMIT THE REAL .env FILE !!
# ============================================================

# ── Admin ────────────────────────────────────────────────────
WEBUI_ADMIN_EMAIL=admin@example.com
WEBUI_ADMIN_PASSWORD=change-me-to-a-strong-password
WEBUI_ADMIN_NAME=YourName

# ── LM Studio (running natively on macOS) ────────────────────
OPENAI_API_KEY=your-lm-studio-api-key
OPENAI_API_BASE_URL=http://localhost:1234/v1

# ── Default Models ───────────────────────────────────────────
DEFAULT_MODELS=qwen/qwen3.5-9b
DEFAULT_PINNED_MODELS=qwen3.5-27b-claude-4.6-opus-reasoning-distilled,qwen/qwen3.5-9b,google/gemma-4-e4b

# ── Database ────────────────────────────────────────────────
POSTGRES_PASSWORD=change-me-to-a-strong-password

# ── n8n ─────────────────────────────────────────────────────
N8N_ENCRYPTION_KEY=change-me-exactly-32-characters!!

# ── Future API Keys (fill in as you go) ─────────────────────
# YOUTUBE_API_KEY=
# FIVERR_API_KEY=
# UPWORK_CLIENT_ID=
# UPWORK_CLIENT_SECRET=
# FACEBOOK_APP_ID=
# FACEBOOK_APP_SECRET=
# ANTHROPIC_API_KEY=
# OPENAI_REAL_API_KEY=
# COMFYUI_URL=http://localhost:8188

# OpenClaw Gateway auth token
OPENCLAW_GATEWAY_TOKEN=change-me-to-a-random-hex-token

# ── LM Studio API Key (used by n8n workflows, memory-broker, pipelines) ──
LM_STUDIO_API_KEY=your-lm-studio-api-key
